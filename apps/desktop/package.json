{
  "name": "desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "tauri": "tauri",
    "build:app": "pnpm build && tauri build",
    "build:portable": "node ../../scripts/build-portable.mjs",
    "build:windows": "pnpm build:portable",
    "build:windows:installer": "pnpm build && tauri build --bundles nsis,msi"
  },
  "dependencies": {
    "@namera/config": "workspace:*",
    "@namera/core": "workspace:*",
    "@namera/destination": "workspace:*",
    "@namera/exec": "workspace:*",
    "@namera/ingest": "workspace:*",
    "@namera/match": "workspace:*",
    "@namera/parse": "workspace:*",
    "@namera/plan": "workspace:*",
    "@namera/provider": "workspace:*"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.5",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "vitest": "^3.2.4"
  }
}
