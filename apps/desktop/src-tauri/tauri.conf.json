{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Namera",
  "version": "0.1.0",
  "identifier": "org.namera.app",
  "build": {
    "beforeDevCommand": "pnpm --dir .. dev",
    "beforeBuildCommand": "pnpm --dir .. build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Namera",
        "width": 1200,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "shortDescription": "Cross-platform Plex-focused media matching, renaming, and tagging tool.",
    "longDescription": "Namera is a local-first desktop tool for matching media files, previewing rename and move plans, and applying safer Plex-friendly organization workflows.",
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    },
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
